{
  "name": "11a3",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "ingest": "tsx packages/pipeline/src/cli.ts",
    "sim": "tsx packages/sim/src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "typecheck": "tsc --noEmit -p packages/domain && tsc --noEmit -p packages/overall && tsc --noEmit -p packages/pipeline && tsc --noEmit -p packages/sim && tsc --noEmit -p apps/web"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "cheerio": "^1.0.0"
  }
}
